    {
      "parameters": {
        "jsCode": "// n8n Code node — Build Apollo Mixed People Search POST body\n// Target: Hiring Managers, Recruiters, Talent Acquisition\n// Updated to work with domain field in output object\n\n// 1) Inputs\nconst items = $input.all();\n\n// 2) Input validation\nif (!items || items.length === 0) {\n  return [{ json: { error: 'No input items received' } }];\n}\n\n// 3) Extract and clean domains from output.domain field\nconst allDomains = Array.from(new Set(\n  items\n    .map(item => {\n      // Access domain from nested output object\n      const domain = String(item.json?.output?.domain || '').trim().toLowerCase();\n      \n      if (!domain) return '';\n      \n      // Clean domain - remove protocol, www, paths\n      let cleanDomain = domain\n        .replace(/^https?:\\/\\//i, '')  // Remove protocol\n        .replace(/^www\\./, '')          // Remove www.\n        .split('/')[0]                  // Get domain only (remove paths)\n        .split('?')[0]                  // Remove query params\n        .split('#')[0]                  // Remove anchors\n        .trim();\n      \n      return cleanDomain;\n    })\n    .filter(d => {\n      // Filter out empty strings and invalid domains\n      if (!d) return false;\n      \n      // Must have at least one dot and valid domain structure\n      const domainRegex = /^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)*\\.[a-z]{2,}$/i;\n      return domainRegex.test(d);\n    })\n));\n\n// 4) Filter out unwanted domains (like linkedin.com from job postings)\nconst excludedDomains = ['linkedin.com', 'indeed.com', 'glassdoor.com', 'monster.com'];\nconst validDomains = allDomains.filter(d => !excludedDomains.includes(d));\n\n// 5) Guard clause\nif (validDomains.length === 0) {\n  return [{ \n    json: { \n      error: 'No valid domains found',\n      totalProcessed: items.length,\n      domainsExtracted: allDomains.length,\n      domainsExcluded: allDomains.length - validDomains.length\n    } \n  }];\n}\n\n// 6) Hiring & Recruiting Titles\nconst titles = [\n  // Talent Acquisition Leadership\n  'VP of Talent Acquisition',\n  'Vice President Talent Acquisition',\n  'VP Talent Acquisition',\n  'Director of Talent Acquisition',\n  'Talent Acquisition Director',\n  'Head of Talent Acquisition',\n  'Head of Recruiting',\n  \n  // Recruiting Leadership\n  'VP of Recruiting',\n  'Vice President Recruiting',\n  'Director of Recruiting',\n  'Recruiting Director',\n  'Director of Recruitment',\n  'Recruitment Director',\n  \n  // HR Leadership (often involved in hiring)\n  'VP of Human Resources',\n  'VP Human Resources',\n  'Director of Human Resources',\n  'HR Director',\n  'Head of HR',\n  'Head of People',\n  'Director of People',\n  'People Director',\n  \n  // Chief Level\n  'Chief Human Resources Officer',\n  'CHRO',\n  'Chief People Officer',\n  'CPO',\n  'Chief Talent Officer',\n  \n  // Senior Recruiters\n  'Senior Recruiter',\n  'Lead Recruiter',\n  'Senior Talent Acquisition Partner',\n  'Principal Recruiter',\n  'Recruiting Manager',\n  'Talent Acquisition Manager',\n  'Talent Acquisition Lead',\n  \n  // Hiring Manager Titles\n  'Hiring Manager',\n  'Technical Recruiter',\n  'Technical Recruiting Manager'\n];\n\n// 7) Build POST body for mixed_people/search\nconst body = {\n  person_titles: titles,\n  person_current_titles: titles,\n  q_organization_domains_list: validDomains,\n  page: 1,\n  per_page: 10\n};\n\n// 8) Output for HTTP Request node with enhanced metadata\nreturn [{\n  json: {\n    url: 'https://api.apollo.io/api/v1/mixed_people/search',\n    method: 'POST',\n    body,\n    // Metadata for debugging\n    metadata: {\n      totalInputItems: items.length,\n      domainsExtracted: allDomains.length,\n      domainsExcluded: allDomains.length - validDomains.length,\n      domainsUsed: validDomains.length,\n      excludedDomainsList: allDomains.filter(d => excludedDomains.includes(d)),\n      targetTitles: titles.length,\n      targetCategory: 'Hiring Managers, Recruiters & Talent Acquisition'\n    },\n    // Full lists for verification\n    processedDomains: validDomains,\n    allExtractedDomains: allDomains,\n    targetTitles: titles\n  }\n}];"
      },
